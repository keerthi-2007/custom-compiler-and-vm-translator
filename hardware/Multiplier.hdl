FullAdder(a=c6e, b=c6f, c=s7a, sum=s7e, carry=c7e);
FullAdder(a=s7b, b=s7c, c=s7d, sum=s7f, carry=c7f);
HalfAdder(a=s7e, b=s7f, sum=outLow[7], carry=c7g);

//col8
FullAdder(a=pp0b8, b=pp1b7, c=pp2b6, sum=s8a, carry=c8a);
FullAdder(a=pp3b5, b=pp4b4, c=pp5b3, sum=s8b, carry=c8b);
