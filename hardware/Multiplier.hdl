HalfAdder(a=s9g, b=s9h, sum=outLow[9], carry=c9i);

//col10
FullAdder(a=pp0b10, b=pp1b9, c=pp2b8, sum=s10a, carry=c10a);
FullAdder(a=pp3b7, b=pp4b6, c=pp5b5, sum=s10b, carry=c10b);
FullAdder(a=pp6b4, b=pp7b3, c=pp8b2, sum=s10c, carry=c10c);
FullAdder(a=pp9b1, b=pp10b0, c=c9a, sum=s10d, carry=c10d);
FullAdder(a=c9b, b=c9c, c=c9d, sum=s10e, carry=c10e);
FullAdder(a=c9e, b=c9f, c=c9g, sum=s10f, carry=c10f);
FullAdder(a=c9h, b=c9i, c=s10a, sum=s10g, carry=c10g);
