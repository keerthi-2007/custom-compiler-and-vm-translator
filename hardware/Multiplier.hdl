HalfAdder(a=s8f, b=s8g, sum=outLow[8], carry=c8h);

//col9
FullAdder(a=pp0b9, b=pp1b8, c=pp2b7, sum=s9a, carry=c9a);
FullAdder(a=pp3b6, b=pp4b5, c=pp5b4, sum=s9b, carry=c9b);
FullAdder(a=pp6b3, b=pp7b2, c=pp8b1, sum=s9c, carry=c9c);
