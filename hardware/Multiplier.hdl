// Multiplier.hdl
// 16x16 Wallace-style multiplier

CHIP Multiplier {
    IN a[16], b[16];
    OUT outLow[16], outHigh[16];

    PARTS:

// ---------- Partial Products ----------
PP(a = a, b = b[0], out[0] = pp0b0, out[1] = pp0b1, out[2] = pp0b2, out[3] = pp0b3, out[4] = pp0b4, out[5] = pp0b5, out[6] = pp0b6, out[7] = pp0b7, out[8] = pp0b8, out[9] = pp0b9, out[10] = pp0b10, out[11] = pp0b11, out[12] = pp0b12, out[13] = pp0b13, out[14] = pp0b14, out[15] = pp0b15);
PP(a = a, b = b[1], out[0] = pp1b0, out[1] = pp1b1, out[2] = pp1b2, out[3] = pp1b3, out[4] = pp1b4, out[5] = pp1b5, out[6] = pp1b6, out[7] = pp1b7, out[8] = pp1b8, out[9] = pp1b9, out[10] = pp1b10, out[11] = pp1b11, out[12] = pp1b12, out[13] = pp1b13, out[14] = pp1b14, out[15] = pp1b15); 
PP(a = a, b = b[2], out[0] = pp2b0, out[1] = pp2b1, out[2] = pp2b2, out[3] = pp2b3, out[4] = pp2b4, out[5] = pp2b5, out[6] = pp2b6, out[7] = pp2b7, out[8] = pp2b8, out[9] = pp2b9, out[10]= pp2b10, out[11] = pp2b11, out[12] = pp2b12, out[13] = pp2b13, out[14] = pp2b14, out[15] = pp2b15);
PP(a = a, b = b[3], out[0] = pp3b0, out[1]=pp3b1,out[2]=pp3b2,out[3]=pp3b3,out[4]=pp3b4,out[5]=pp3b5,out[6]=pp3b6,out[7]=pp3b7,out[8]=pp3b8,out[9]=pp3b9,out[10]=pp3b10,out[11]=pp3b11,out[12]=pp3b12,out[13]=pp3b13,out[14]=pp3b14,out[15]=pp3b15);
PP(a = a, b = b[4], out[0] = pp4b0, out[1]=pp4b1,out[2]=pp4b2,out[3]=pp4b3,out[4]=pp4b4,out[5]=pp4b5,out[6]=pp4b6,out[7]=pp4b7,out[8]=pp4b8,out[9]=pp4b9,out[10]=pp4b10,out[11]=pp4b11,out[12]=pp4b12,out[13]=pp4b13,out[14]=pp4b14,out[15]=pp4b15);
PP(a = a, b = b[5], out[0] = pp5b0, out[1]=pp5b1,out[2]=pp5b2,out[3]=pp5b3,out[4]=pp5b4,out[5]=pp5b5,out[6]=pp5b6,out[7]=pp5b7,out[8]=pp5b8,out[9]=pp5b9,out[10]=pp5b10,out[11]=pp5b11,out[12]=pp5b12,out[13]=pp5b13,out[14]=pp5b14,out[15]=pp5b15);
PP(a = a, b = b[6], out[0] = pp6b0, out[1]=pp6b1,out[2]=pp6b2,out[3]=pp6b3,out[4]=pp6b4,out[5]=pp6b5,out[6]=pp6b6,out[7]=pp6b7,out[8]=pp6b8,out[9]=pp6b9,out[10]=pp6b10,out[11]=pp6b11,out[12]=pp6b12,out[13]=pp6b13,out[14]=pp6b14,out[15]=pp6b15);
PP(a = a, b = b[7], out[0] = pp7b0, out[1]=pp7b1,out[2]=pp7b2,out[3]=pp7b3,out[4]=pp7b4,out[5]=pp7b5,out[6]=pp7b6,out[7]=pp7b7,out[8]=pp7b8,out[9]=pp7b9,out[10]=pp7b10,out[11]=pp7b11,out[12]=pp7b12,out[13]=pp7b13,out[14]=pp7b14,out[15]=pp7b15);
PP(a = a, b = b[8], out[0] = pp8b0, out[1]=pp8b1,out[2]=pp8b2,out[3]=pp8b3,out[4]=pp8b4,out[5]=pp8b5,out[6]=pp8b6,out[7]=pp8b7,out[8]=pp8b8,out[9]=pp8b9,out[10]=pp8b10,out[11]=pp8b11,out[12]=pp8b12,out[13]=pp8b13,out[14]=pp8b14,out[15]=pp8b15);
PP(a = a, b = b[9], out[0] = pp9b0, out[1]=pp9b1,out[2]=pp9b2,out[3]=pp9b3,out[4]=pp9b4,out[5]=pp9b5,out[6]=pp9b6,out[7]=pp9b7,out[8]=pp9b8,out[9]=pp9b9,out[10]=pp9b10,out[11]=pp9b11,out[12]=pp9b12,out[13]=pp9b13,out[14]=pp9b14,out[15]=pp9b15);
PP(a = a, b = b[10], out[0] = pp10b0, out[1]=pp10b1,out[2]=pp10b2,out[3]=pp10b3,out[4]=pp10b4,out[5]=pp10b5,out[6]=pp10b6,out[7]=pp10b7,out[8]=pp10b8,out[9]=pp10b9,out[10]=pp10b10,out[11]=pp10b11,out[12]=pp10b12,out[13]=pp10b13,out[14]=pp10b14,out[15]=pp10b15);
PP(a = a, b = b[11], out[0] = pp11b0, out[1]=pp11b1,out[2]=pp11b2,out[3]=pp11b3,out[4]=pp11b4,out[5]=pp11b5,out[6]=pp11b6,out[7]=pp11b7,out[8]=pp11b8,out[9]=pp11b9,out[10]=pp11b10,out[11]=pp11b11,out[12]=pp11b12,out[13]=pp11b13,out[14]=pp11b14,out[15]=pp11b15);
PP(a = a, b = b[12], out[0] = pp12b0, out[1]=pp12b1,out[2]=pp12b2,out[3]=pp12b3,out[4]=pp12b4,out[5]=pp12b5,out[6]=pp12b6,out[7]=pp12b7,out[8]=pp12b8,out[9]=pp12b9,out[10]=pp12b10,out[11]=pp12b11,out[12]=pp12b12,out[13]=pp12b13,out[14]=pp12b14,out[15]=pp12b15);
PP(a = a, b = b[13], out[0] = pp13b0, out[1]=pp13b1,out[2]=pp13b2,out[3]=pp13b3,out[4]=pp13b4,out[5]=pp13b5,out[6]=pp13b6,out[7]=pp13b7,out[8]=pp13b8,out[9]=pp13b9,out[10]=pp13b10,out[11]=pp13b11,out[12]=pp13b12,out[13]=pp13b13,out[14]=pp13b14,out[15]=pp13b15);
PP(a = a, b = b[14], out[0] = pp14b0, out[1]=pp14b1,out[2]=pp14b2,out[3]=pp14b3,out[4]=pp14b4,out[5]=pp14b5,out[6]=pp14b6,out[7]=pp14b7,out[8]=pp14b8,out[9]=pp14b9,out[10]=pp14b10,out[11]=pp14b11,out[12]=pp14b12,out[13]=pp14b13,out[14]=pp14b14,out[15]=pp14b15);
PP(a = a, b = b[15], out[0] = pp15b0, out[1]=pp15b1,out[2]=pp15b2,out[3]=pp15b3,out[4]=pp15b4,out[5]=pp15b5,out[6]=pp15b6,out[7]=pp15b7,out[8]=pp15b8,out[9]=pp15b9,out[10]=pp15b10,out[11]=pp15b11,out[12]=pp15b12,out[13]=pp15b13,out[14]=pp15b14,out[15]=pp15b15);


// Wallace tree reduction

//col0
Or(a=pp0b0, b=false, out=outLow[0]);

//col1
HalfAdder(a=pp0b1, b=pp1b0, sum=outLow[1], carry=c1a);

//col2
FullAdder(a=pp0b2, b=pp1b1, c=pp2b0, sum=s2a, carry=c2a);
HalfAdder(a=s2a, b=c1a, sum=outLow[2], carry=c2b);

//col3
FullAdder(a=pp0b3, b=pp1b2, c=pp2b1, sum=s3a, carry=c3a);
FullAdder(a=pp3b0, b=c2a, c=c2b, sum=s3b, carry=c3b);
HalfAdder(a=s3a, b=s3b, sum=outLow[3], carry=c3c);

//col4
FullAdder(a=pp0b4, b=pp1b3, c=pp2b2, sum=s4a, carry=c4a);
FullAdder(a=pp3b1, b=pp4b0, c=c3a, sum=s4b, carry=c4b);
FullAdder(a=c3b, b=c3c, c=s4a, sum=s4c, carry=c4c);
HalfAdder(a=s4b, b=s4c, sum=outLow[4], carry=c4d);

//col5
FullAdder(a=pp0b5, b=pp1b4, c=pp2b3, sum=s5a, carry=c5a);
FullAdder(a=pp3b2, b=pp4b1, c=pp5b0, sum=s5b, carry=c5b);
FullAdder(a=c4a, b=c4b, c=c4c, sum=s5c, carry=c5c);
FullAdder(a=c4d, b=s5a, c=s5b, sum=s5d, carry=c5d);
HalfAdder(a=s5c, b=s5d, sum=outLow[5], carry=c5e);

//col6
FullAdder(a=pp0b6, b=pp1b5, c=pp2b4, sum=s6a, carry=c6a);
FullAdder(a=pp3b3, b=pp4b2, c=pp5b1, sum=s6b, carry=c6b);
FullAdder(a=pp6b0, b=c5a, c=c5b, sum=s6c, carry=c6c);
FullAdder(a=c5c, b=c5d, c=c5e, sum=s6d, carry=c6d);
FullAdder(a=s6a, b=s6b, c=s6c, sum=s6e, carry=c6e);
HalfAdder(a=s6d, b=s6e, sum=outLow[6], carry=c6f);

//col7
FullAdder(a=pp0b7, b=pp1b6, c=pp2b5, sum=s7a, carry=c7a);
